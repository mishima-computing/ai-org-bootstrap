      "const": "genius"
    },
    "objective": {
      "type": "string"
    },
    "substrate_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref_type",
          "locator",
          "summary"
        ],
        "properties": {
          "ref_type": {
            "enum": [
              "repo_pointer",
              "official_spec",
              "standard",
              "paper",
              "mature_implementation",
              "run_artifact"
            ]
          },
          "locator": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "official_spec_evidence": {
