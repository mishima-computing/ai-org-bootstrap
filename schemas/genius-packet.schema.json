{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-quality-bootstrap.genius-packet.v2",
  "type": "object",
  "required": [
    "role_id",
    "objective",
    "substrate_inputs",
    "official_spec_evidence",
    "repo_evidence",
    "kept_hypotheses",
    "refuted_hypotheses",
    "unverified_hypotheses",
    "what_not_to_copy",
    "handoff_to_aufheben"
  ],
