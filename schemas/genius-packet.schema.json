    "kept_hypotheses": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "hypothesis_id",
          "mechanism",
          "score",
          "verification_status",
          "repo_evidence_refs",
          "external_refs",
          "expected_benefit",
          "risks",
          "rejection_conditions",
          "what_not_to_copy"
        ],
        "properties": {
          "hypothesis_id": {
            "type": "string"
          },
          "mechanism": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "description": "Advisory score only; keep/drop authority rests with aufheben-designer."
          },
          "verification_status": {
            "enum": [
              "confirmed",
